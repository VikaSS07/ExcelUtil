<mvc:View
    controllerName="excelutil.controller.Index"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:u="sap.ui.unified"
    xmlns:t="sap.ui.table"
>
    <Page
        id="page"
        title="{i18n>title}"
    >
        <content>
            <VBox class="sapUiMediumMargin">
                <Title
                    text="Parsed Student Records"
                    level="H2"
                    class="sapUiSmallMarginBottom"
                />

                <t:Table
                    id="studentTable"
                    rows="{localData>/students}"
                    selectionMode="None"
                    visibleRowCount="7"
                    ariaLabelledBy="title"
                >
                    <t:extension>
                        <OverflowToolbar style="Clear" height="auto">
                                <Label
                                    text="Select Excel File:"
                                    labelFor="fileUploader"
                                    design="Bold"
                                />
                                <u:FileUploader
                                    id="fileUploader"
                                    name="myFileUpload"
                                    fileType="xlsx"
                                    change="onFileChange"
                                    width="400px"
                                    placeholder="Choose an .xlsx file..."
                                />
                                <ToolbarSpacer/>
                                <Button
                                    id="uploadBtn"
                                    text="Upload and Process Data"
                                    type="Emphasized"
                                    press="onUploadPress"
                                    class="sapUiSmallMarginTop"
                                    enabled="false"
                                />
                        </OverflowToolbar>
                    </t:extension>
                    <t:columns>
                        <t:Column width="150px">
                            <Label text="Student ID" />
                            <t:template>
                                <Text
                                    text="{localData>studentId}"
                                    wrapping="false"
                                />
                            </t:template>
                        </t:Column>

                        <t:Column width="250px" >
                            <Label text="Student Name" />
                            <t:template>
                                <Text
                                    text="{localData>studentName}"
                                    wrapping="false"
                                />
                            </t:template>
                        </t:Column>

                        <t:Column width="200px">
                            <Label text="Admission Date" />
                            <t:template>
                                <Text
                                    text="{localData>admissionDate}"
                                    wrapping="false"
                                />
                            </t:template>
                        </t:Column>
                    </t:columns>
                </t:Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
